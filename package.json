{
  "name": "rail",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "./scripts/run-vite-dev.sh",
    "dev:isolated": "RAIL_CODEX_HOME_MODE=isolated ./scripts/run-vite-dev.sh",
    "build": "./scripts/with-modern-node.sh sh -c 'tsc && vite build'",
    "check:arch": "./scripts/with-modern-node.sh node scripts/check-architecture.mjs",
    "check:cycles": "./scripts/with-modern-node.sh node scripts/check-cycles.mjs",
    "check:css": "./scripts/with-modern-node.sh node scripts/check-css-important.mjs",
    "test": "./scripts/with-modern-node.sh vitest run --passWithNoTests",
    "test:e2e:tasks": "./scripts/with-modern-node.sh node scripts/e2e/tasks-regression.mjs",
    "test:e2e:tasks:web-mock": "RAIL_E2E_URL=http://localhost:1420/?tasks_mock_runtime=1 ./scripts/with-modern-node.sh node scripts/e2e/tasks-regression.mjs",
    "test:e2e:tasks:tauri-smoke": "./scripts/with-modern-node.sh node scripts/e2e/tasks-tauri-smoke.mjs",
    "check": "npm run check:arch && npm run check:cycles && npm run check:css && npm run build && npm run test",
    "preview": "./scripts/with-modern-node.sh vite preview",
    "tauri": "./scripts/with-modern-node.sh tauri",
    "tauri:dev": "npm run tauri:dev:isolated",
    "tauri:dev:isolated": "RAIL_CODEX_HOME_MODE=isolated ./scripts/with-modern-node.sh tauri dev",
    "tauri:dev:global": "RAIL_CODEX_HOME_MODE=global ./scripts/with-modern-node.sh tauri dev",
    "dashboard:crawl": "cargo run --manifest-path src-tauri/Cargo.toml --bin dashboard_crawler -- --cwd ."
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "playwright-core": "^1.58.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.9.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.1"
  }
}
